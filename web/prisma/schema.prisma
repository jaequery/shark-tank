generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Evaluation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectName  String
  projectUrl   String?
  description  String
  askAmount    String?

  narration    String   @db.Text
  pitch        String   @db.Text
  sharkDialog  String   @db.Text
  theGood      String   @db.Text
  theConcerns  String   @db.Text
  hardQuestions String  @db.Text
  verdict      String   @db.Text
  deal         String?

  overallScore Int

  scores EvaluationScore[]
}

model EvaluationScore {
  id           String     @id @default(cuid())
  evaluationId String
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  category String
  score    Int
  oneLiner String

  @@unique([evaluationId, category])
}
